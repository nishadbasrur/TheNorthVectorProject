{
  "name": "functions",
  "private": true,
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=lib/index.js --external:firebase-admin --external:firebase-functions",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "@googleapis/calendar": "^15.0.0",
    "@googleapis/gmail": "^17.0.0",
    "@notionhq/client": "^5.22.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "resend": "^6.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
