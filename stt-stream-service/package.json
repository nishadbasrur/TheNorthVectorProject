{
  "name": "stt-stream-service",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": "22"
  },
  "main": "server.js",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --target=node22 --outfile=server.js --external:ws --external:@google-cloud/speech --external:firebase-admin",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node server.js"
  },
  "dependencies": {
    "@google-cloud/speech": "^7.5.0",
    "firebase-admin": "^14.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.0"
  }
}
