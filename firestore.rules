rules_version = '2';

// Single-user restriction: only the owner's authenticated account may
// read or write data in this project, and only in the specific
// collections listed below.
//
// Deliberately NOT using a catch-all `match /{document=**}` for the
// owner-accessible collections: Firestore combines the results of every
// `match` block whose path pattern structurally matches a request with a
// logical OR, so a broad catch-all sitting alongside a "deny all" block
// for a restricted collection (like plaid_items) would NOT actually
// override that deny — the owner-authenticated catch-all would still
// independently match and grant access. Enumerating each real collection
// explicitly avoids that ambiguity entirely: a request path either
// belongs to exactly one of these non-overlapping `match` blocks, or it
// is denied by default (no block matches).
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null
        && request.auth.token.email == "nishadbasrur@gmail.com";
    }

    // Collections the owner's authenticated browser session reads and
    // writes directly via the client SDK.
    match /tasks/{document=**} {
      allow read, write: if isOwner();
    }
    match /goals/{document=**} {
      allow read, write: if isOwner();
    }
    match /projects/{document=**} {
      allow read, write: if isOwner();
    }
    match /decisions/{document=**} {
      allow read, write: if isOwner();
    }
    match /memories/{document=**} {
      allow read, write: if isOwner();
    }

    // plaid_items holds encrypted bank access tokens. Even the owner's
    // own browser session must never read or write it directly — only
    // trusted server code (the Admin SDK, which bypasses these rules
    // entirely) is allowed to touch this collection.
    match /plaid_items/{document=**} {
      allow read, write: if false;
    }

    // daily-runs is written only by the scheduled Cloud Function via the
    // Admin SDK, which bypasses these rules entirely regardless of what's
    // written here. The owner may still read their own risk-scan history
    // in the app; no direct client write path is allowed, same pattern as
    // plaid_items.
    match /daily-runs/{document=**} {
      allow read: if isOwner();
      allow write: if false;
    }

    // inbox holds raw messages captured from the iOS Shortcut ingest
    // endpoint (app/api/v1/messages/ingest), authenticated by a shared
    // secret rather than a Firebase session. Only that trusted server
    // route (via the Admin SDK, which bypasses these rules entirely) may
    // write here — no client, including the owner's own browser session,
    // may read or write it directly. Same pattern as plaid_items.
    match /inbox/{document=**} {
      allow read, write: if false;
    }

    // alert_state de-duplicates the Calendar/Notion urgency scan (see
    // functions/src/urgency-scan.ts) — one doc per already-alerted
    // event/item so the same thing doesn't re-notify every 15-minute
    // cycle. Only the scheduled Cloud Function (Admin SDK) writes it.
    match /alert_state/{document=**} {
      allow read: if isOwner();
      allow write: if false;
    }

    // alerts is the audit log of push notifications actually sent —
    // summary/subject only, never raw email body content (see the
    // Gmail-specific handling notes in
    // docs/integrations/calendar-notion-gmail-task.md). Only the Cloud
    // Function writes it.
    match /alerts/{document=**} {
      allow read: if isOwner();
      allow write: if false;
    }

    // gmail_surfaced de-duplicates the on-demand Gmail urgency check (see
    // lib/gmail-urgency.ts, invoked by the voice tool dispatcher's
    // check_email tool) — one doc per evaluated message id with a
    // surfacedAt timestamp, so the same message isn't re-evaluated within
    // the TTL window. Written directly by that trusted server code via the
    // Admin SDK; no client write path.
    match /gmail_surfaced/{document=**} {
      allow read: if isOwner();
      allow write: if false;
    }

    // push_subscriptions holds this device's Firebase Cloud Messaging
    // registration token, written directly by the owner's own signed-in
    // browser session when they enable urgent alerts in Settings — same
    // access model as tasks/goals, not the Admin-SDK-only pattern above.
    match /push_subscriptions/{document=**} {
      allow read, write: if isOwner();
    }

    // preferences holds standing instructions detected from live
    // conversation turns (see lib/preference-detector.ts) — distinct from
    // memories, which holds historical facts imported from the ChatGPT
    // export. Written only by the trusted server routes (Judgment Engine /
    // voice routes) via the Admin SDK, which bypasses these rules entirely;
    // the owner may still read their own stated preferences in the app.
    match /preferences/{document=**} {
      allow read: if isOwner();
      allow write: if false;
    }

    // voice_sessions holds short-lived conversational turn history for
    // multi-turn voice continuity (pronoun resolution across separate spoken
    // utterances) — see North_Vector_JARVIS_Tool_Calling_Migration_Plan.md
    // Section 6. Written only by app/api/v1/voice/respond via the Admin SDK;
    // no client write path.
    match /voice_sessions/{document=**} {
      allow read: if isOwner();
      allow write: if false;
    }

    // synthesis_runs is the audit trail for each Synthesis Engine pass —
    // source counts and which connections were found/delivered, never raw
    // source content (same boundary Gmail already enforces). Written only
    // by the scheduled scan (functions/src/synthesis-scan.ts) and the
    // on-demand check (app/api/v1/synthesis/check-now) via the Admin SDK.
    // See North_Vector_Synthesis_Engine_Plan.md Section 8/9.
    match /synthesis_runs/{document=**} {
      allow read: if isOwner();
      allow write: if false;
    }

    // synthesis_connections de-duplicates cross-source connections the
    // Synthesis Engine has already surfaced — one doc per distinct
    // source-pair combination, re-surfaced after 6 hours rather than a
    // one-shot flag (a connection can become more or less relevant between
    // runs). Written only by the same trusted server code as
    // synthesis_runs.
    match /synthesis_connections/{document=**} {
      allow read: if isOwner();
      allow write: if false;
    }

    // capability_gaps logs requests North couldn't fulfill with any current
    // tool (see lib/capability-gap-store.ts, called via the
    // note_capability_gap tool) — a human-reviewed backlog, not something
    // that triggers any automatic code change. Written only by the voice
    // respond route via the Admin SDK.
    match /capability_gaps/{document=**} {
      allow read: if isOwner();
      allow write: if false;
    }

    // tool_errors is the automatic structured-failure log every tool
    // handler writes to on its own catch block (see lib/tool-error-log.ts,
    // called from lib/tool-dispatcher.ts) — pure observability, no
    // AI/agent decision involved. Written only by trusted server code via
    // the Admin SDK; the owner may browse it at /tool-errors.
    match /tool_errors/{document=**} {
      allow read: if isOwner();
      allow write: if false;
    }
  }
}
