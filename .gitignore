node_modules
.next
.env.local
tsconfig.tsbuildinfo
.DS_Store

.agents/
skills-lock.json

.claude/
.agents/
skills-lock.json

# Local personal imports — the whole directory, not per-subfolder, so a
# newly-added import source (e.g. true-export/) is never silently untracked.
data/imports/

# Local memory database
data/memories/

# Cloud Functions build output (bundled by esbuild, not source)
functions/lib/

# stt-stream-service build output (bundled by esbuild, not source — see
# that directory's package.json build script)
stt-stream-service/server.js

# Cloud Functions plain (non-secret) env vars, same treatment as .env.local
functions/.env

# Wake-word ONNX models + onnxruntime-web WASM binaries — copied from
# node_modules by scripts/copy-wake-word-assets.js (predev/prebuild), not
# source. node_modules is already gitignored; duplicating ~80MB of binaries
# into git history would be pure bloat for files npm already manages.
public/models/
public/ort/

# One-time throwaway OAuth re-consent script (see its own header comment) —
# a local tool to run once when widening Gmail/Calendar scopes, not app code.
scripts/oauth-widen-scopes.js

# Mac Mini Messages agent's real secret + runtime state — machine-specific,
# never committed. agent.js and the LaunchAgent plist template are the real
# source; .env holds the actual MAC_AGENT_INGEST_SECRET value.
scripts/mac-messages-agent/.env
scripts/mac-messages-agent/state.json
scripts/mac-messages-agent/agent.lock
